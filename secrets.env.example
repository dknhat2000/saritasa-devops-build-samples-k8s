# HMAC secret — must match the webhook secret configured in the GitHub App settings
GITHUB_WEBHOOK_SECRET=

# GitHub Container Registry — PAT with write:packages scope for image push
GHCR_TOKEN=
GITHUB_USER=

# SSH key for git-clone task (defaults to ~/.ssh/id_ed25519)
GIT_SSH_KEY=

# GitHub App credentials — required for PAC webhook authentication
# App ID: found on the App settings page (numeric)
# Private key: path to the downloaded .pem file (e.g. ~/.ssh/pac-github-app.pem)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_FILE=
